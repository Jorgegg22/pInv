---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const posts = (await getCollection('ia'))
  .sort((a: any, b: any) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());
---

<Layout 
  title="IA Práctica: Herramientas para ganar dinero y automatizar | CarteraIA" 
  description="Descubre cómo usar ChatGPT, Claude y agentes de IA para mejorar tu productividad y tus finanzas personales. Guías paso a paso."
>
  <header class="bg-bg-secondary border-b border-border py-20">
    <div class="container mx-auto px-6">
      <span class="text-accent-ia font-bold tracking-widest uppercase text-sm">Pilar de Contenido</span>
      <h1 class="text-5xl md:text-6xl mt-4 mb-6">Inteligencia Artificial</h1>
      <p class="text-xl text-text-secondary max-w-2xl leading-relaxed">
        No solo hablamos de teoría. Te enseñamos a implementar herramientas de IA generativa para crear flujos de ingresos y automatizar decisiones financieras.
      </p>
    </div>
  </header>

  <section class="container mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post: any) => (
        <ArticleCard post={post} />
      ))}
    </div>
  </section>
</Layout>
