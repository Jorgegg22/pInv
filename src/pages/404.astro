---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Página no encontrada" 
  description="Error 404 - La página que buscas no existe en CarteraIA."
>
  <div class="container mx-auto px-6 py-32 flex flex-col items-center justify-center text-center min-h-[60vh]">
    <span class="text-accent-inv font-bold tracking-widest uppercase text-sm mb-4">Error 404</span>
    <h1 class="text-6xl md:text-8xl mb-6 font-serif">Mercado Cerrado</h1>
    <p class="text-xl text-text-secondary max-w-2xl mb-10">
      Parece que la página que buscas ha sido delistada, movida o nunca existió. No te preocupes, hay muchas otras oportunidades de inversión esperándote.
    </p>
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/" class="btn-primary text-lg px-8 py-4">
        Volver al inicio
      </a>
      <a href="/inversiones" class="btn-secondary text-lg px-8 py-4">
        Ver Inversiones
      </a>
    </div>
  </div>
</Layout>
