---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto | CarteraIA" description="Contacta con el equipo de CarteraIA para dudas o sugerencias.">
  <div class="container mx-auto px-6 py-20 max-w-3xl text-center">
    <h1 class="text-4xl font-serif mb-8">Contacto</h1>
    <p class="text-xl text-text-secondary mb-12">¿Tienes alguna duda sobre nuestras herramientas o artículos? Escríbenos.</p>
    
    <div class="card inline-block">
      <p class="text-text-secondary mb-2">Email oficial:</p>
      <a href="mailto:hola@carteraia.com" class="text-2xl font-bold text-accent-inv hover:underline">hola@carteraia.com</a>
    </div>
  </div>
</Layout>
