---
interface Props {
  nombre: string;
  descripcion: string;
  link: string;
  logo: string;
  caracteristicas: string[];
}

const { nombre, descripcion, link, logo, caracteristicas } = Astro.props;
---

<div class="my-10 p-6 rounded-2xl border-2 border-border-ui bg-bg-card flex flex-col md:flex-row gap-6 items-center">
  <div class="w-24 h-24 shrink-0 bg-white rounded-xl p-2 flex items-center justify-center">
    <img src={logo} alt={`Logo de ${nombre}`} class="max-w-full max-h-full object-contain" />
  </div>
  
  <div class="flex-1">
    <h4 class="text-xl font-bold mb-2 m-0">{nombre}</h4>
    <p class="text-sm text-tx-sec mb-4 m-0">{descripcion}</p>
    <ul class="flex flex-wrap gap-2 p-0 m-0 list-none">
      {caracteristicas.map(car => (
        <li class="text-xs bg-acc-primary/10 text-acc-primary px-2 py-1 rounded-md font-bold m-0">
          ✓ {car}
        </li>
      ))}
    </ul>
  </div>

  <div class="w-full md:w-auto flex flex-col gap-2">
    <a href={link} target="_blank" rel="noopener nofollow" class="w-full text-center px-6 py-3 bg-acc-primary text-white font-bold rounded-xl hover:opacity-90 transition-all">
      Abrir cuenta gratis
    </a>
    <span class="text-[10px] text-tx-muted text-center">Enlace de afiliado</span>
  </div>
</div>